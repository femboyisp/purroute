[router]
listen = "127.0.0.1:1337"                        # Address and port for the router to listen on. Can be an array of addresses:ports or a single address:port (ie: ["[::]:1337", "10.13.37.1:1337"]
log = true
verbose = true
debug = true
auth = true
# chain = "Tor"                                  # Single mode: Use a single proxy by label
# chain = "strict-chain"                         # Strict mode: Use a chain in order
# chain = "random-chain"                         # Random mode: Pick random proxy(ies) from chain
metrics_listen = "127.0.0.1:9100"                # (Optional) Local-only Prometheus /metrics endpoint

# Accounts (username/password + bandwidth_limit) live in the `accounts` table.
# The router reads them through its AuthBackend; create/manage them however you
# like (direct SQL, your own service, etc.).

[database]
host = "localhost"
port = 5432
user = "purroute"
#password = "purroute"
dbname = "purroute"

# Individual proxy configurations (External Connections)
[[proxy]] # Each [[proxy]] block is a separate proxy configuration block. If only one is present then it is a single proxy configuration
label = "Tor"                          # Proxy types supported: Http, Https, Socks4, Socks5
proxy_type = "Socks5"
address = "127.0.0.1:9050"                      # If port is not specified (ie: in onion/i2p addresses) we default to 80

[[proxy]]
label = "HttpProxy"
proxy_type = "Http"                             # If just Http or Https is specified then it will be strictly that protocol
address = "proxy2.example.com:8080"             # If port is not specified (ie: in onion/i2p addresses) we default to 80
username = "user123"                            # (Optional) Username for proxy authentication
password = "pass456"                            # (Optional) Password for proxy authentication

[[proxy]]
label = "Kitty"
proxy_type = "Socks5"
address = "kitty.example.com:1080"

# Chain configurations
# Strict mode: Use proxies in exact order
[[chain]]
chain_id = "strict-chain"
mode = "strict"                                 # Use proxies in the order specified
proxies = ["Tor", "HttpProxy"]                  # Will always go: Tor -> HttpProxy

# Random mode: Pick one random proxy from the list
[[chain]]
chain_id = "random-chain"
mode = "random"                                 # Randomly select from the list
proxies = ["Tor", "HttpProxy", "Kitty"]         # Will pick ONE random proxy on each connection

# Random mode with count: Pick multiple random proxies
[[chain]]
chain_id = "random-multi"
mode = "random"
count = 2                                       # Pick 2 random proxies from the list
proxies = ["Tor", "HttpProxy", "Kitty"]         # Will pick TWO random proxies and chain them
